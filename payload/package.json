{
  "name": "mini-payload",
  "version": "1.0.0",
  "description": "A production-ready reference implementation for learning Payload CMS with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "payload": "payload"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.82.0-canary.0",
    "@payloadcms/next": "3.82.0-canary.0",
    "@payloadcms/richtext-lexical": "3.82.0-canary.0",
    "@payloadcms/ui": "3.82.0-canary.0",
    "clsx": "2.1.1",
    "graphql": "16.9.0",
    "next": "16.1.6",
    "payload": "3.82.0-canary.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5",
    "tailwind-merge": "2.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@next/eslint-plugin-next": "16.2.2",
    "@playwright/test": "1.45.0",
    "@types/node": "22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "10.4.19",
    "eslint": "10.1.0",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react-hooks": "7.0.1",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.0",
    "typescript": "5.7.2",
    "vitest": "2.0.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
