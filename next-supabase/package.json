    "@stripe/stripe-js": "4.0.0",
    "@supabase/ssr": "0.5.0",
    "@supabase/supabase-js": "2.45.0",
    "@tanstack/react-query": "5.51.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.400.0",
    "next": "15.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.53.0",
