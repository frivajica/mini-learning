{
  "name": "mini-next-supabase",
  "version": "1.0.0",
  "description": "Next.js with Supabase - Learn Supabase patterns, real-time subscriptions, Stripe subscriptions, testing, and CI/CD",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
